import java.util.HashMap;
import java.util.Map;

public class TrainApp {

    public static void main(String[] args) {

        System.out.println("=== Train Consist Management App ===");

        // Step 1: Create HashMap
        HashMap<String, Integer> bogieCapacity = new HashMap<>();

        // Step 2: Insert bogie-capacity mappings
        System.out.println("\nAdding Bogie Capacities...");
        bogieCapacity.put("Sleeper", 72);
        bogieCapacity.put("AC Chair", 60);
        bogieCapacity.put("First Class", 24);

        // Step 3: Display all mappings
        System.out.println("\nBogie Capacity Details:");
        displayCapacity(bogieCapacity);

        // Step 4: Example lookup
        System.out.println("\nChecking capacity of Sleeper...");
        int capacity = bogieCapacity.get("Sleeper");
        System.out.println("Sleeper Capacity: " + capacity);
    }

    // Method to display map entries
    public static void displayCapacity(HashMap<String, Integer> map) {

        System.out.println("\n--- Capacity Mapping ---");

        for (Map.Entry<String, Integer> entry : map.entrySet()) {
            System.out.println(entry.getKey() + " → " + entry.getValue() + " seats");
        }
    }
}
