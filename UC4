import java.util.LinkedList;

public class TrainApp {

    public static void main(String[] args) {

        System.out.println("=== Train Consist Management App ===");

        // Step 1: Create LinkedList
        LinkedList<String> train = new LinkedList<>();

        // Step 2: Add Bogies
        train.add("Engine");
        train.add("Sleeper");
        train.add("AC");
        train.add("Cargo");
        train.add("Guard");

        System.out.println("\nInitial Train Consist:");
        displayTrain(train);

        // Step 3: Insert Pantry Car at position 2
        System.out.println("\nInserting Pantry Car at position 2...");
        train.add(2, "Pantry Car");

        displayTrain(train);

        // Step 4: Remove first and last bogie
        System.out.println("\nRemoving first and last bogies...");
        train.removeFirst();
        train.removeLast();

        // Step 5: Final consist
        System.out.println("\nFinal Train Consist:");
        displayTrain(train);
    }

    // Display method
    public static void displayTrain(LinkedList<String> train) {

        System.out.println("\n--- Train Consist Summary ---");

        int index = 1;
        for (String bogie : train) {
            System.out.println("Bogie " + index + ": " + bogie);
            index++;
        }
    }
}
