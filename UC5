import java.util.LinkedHashSet;

public class TrainApp {

    public static void main(String[] args) {

        System.out.println("=== Train Consist Management App ===");

        // Step 1: Create LinkedHashSet
        LinkedHashSet<String> train = new LinkedHashSet<>();

        // Step 2: Add bogies
        System.out.println("\nAdding Bogies...");
        train.add("Engine");
        train.add("Sleeper");
        train.add("Cargo");
        train.add("Guard");

        // Step 3: Attempt duplicate
        System.out.println("\nAttempting to add duplicate 'Sleeper'...");
        boolean isAdded = train.add("Sleeper");

        if (!isAdded) {
            System.out.println("Duplicate ignored: Sleeper");
        }

        // Step 4: Display final formation
        System.out.println("\nFinal Train Formation:");
        displayTrain(train);
    }

    // Display method
    public static void displayTrain(LinkedHashSet<String> train) {

        System.out.println("\n--- Train Consist Summary ---");

        int index = 1;
        for (String bogie : train) {
            System.out.println("Bogie " + index + ": " + bogie);
            index++;
        }
    }
}
